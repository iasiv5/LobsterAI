{
  "id": "lobster-media-generation",
  "name": "LobsterMediaGeneration",
  "description": "Image/video generation and AI skin management tools powered by LobsterAI.",
  "contracts": {
    "tools": [
      "lobsterai_image_generate",
      "lobsterai_video_generate",
      "lobsterai_skin_manage"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "callbackUrl": {
        "type": "string",
        "description": "LobsterAI HTTP callback URL for media generation requests"
      },
      "secret": {
        "type": "string",
        "description": "Shared secret for callback authentication"
      },
      "requestTimeoutMs": {
        "type": "number",
        "minimum": 1000,
        "description": "Request timeout in milliseconds"
      }
    }
  }
}
