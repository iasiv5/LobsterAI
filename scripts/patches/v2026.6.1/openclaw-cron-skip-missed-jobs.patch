+++ b/src/cron/service/timer.skip-missed-jobs.test.ts
@@ -0,0 +1,167 @@
+import { describe, expect, it, vi } from "vitest";
+import {
+  createDefaultIsolatedRunner,
+  createDueIsolatedJob,
+  setupCronRegressionFixtures,
+} from "../../../test/helpers/cron/service-regression-fixtures.js";
+import { saveCronStore } from "../store.js";
+import type { CronJob } from "../types.js";
+import { createCronServiceState, type CronServiceDeps } from "./state.js";
+import { onTimer, runMissedJobs } from "./timer.js";
+
+const fixtures = setupCronRegressionFixtures({ prefix: "cron-skip-missed-jobs-" });
+
+const LAST_RUN_AT = Date.parse("2026-07-11T15:07:00.000Z");
+const MISSED_SLOT_AT = Date.parse("2026-07-12T15:07:00.000Z");
+const STARTUP_AT = Date.parse("2026-07-12T21:09:00.000Z");
+const NEXT_SLOT_AT = Date.parse("2026-07-13T15:07:00.000Z");
+const EVERY_MS = 2 * 60 * 60 * 1_000;
+
+function createMissedDailyCronJob(id: string): CronJob {
+  return {
+    id,
+    name: id,
+    enabled: true,
+    createdAtMs: LAST_RUN_AT - 86_400_000,
+    updatedAtMs: LAST_RUN_AT,
+    schedule: { kind: "cron", expr: "7 15 * * *", tz: "UTC", staggerMs: 0 },
+    sessionTarget: "isolated",
+    wakeMode: "next-heartbeat",
+    payload: { kind: "agentTurn", message: id },
+    delivery: { mode: "none" },
+    state: { lastRunAtMs: LAST_RUN_AT, lastRunStatus: "ok", nextRunAtMs: MISSED_SLOT_AT },
+  };
+}
+
+function createMissedEveryJob(id: string): CronJob {
+  const lastRunAtMs = STARTUP_AT - 3 * EVERY_MS;
+  return {
+    id,
+    name: id,
+    enabled: true,
+    createdAtMs: lastRunAtMs - EVERY_MS,
+    updatedAtMs: lastRunAtMs,
+    schedule: { kind: "every", everyMs: EVERY_MS, anchorMs: lastRunAtMs },
+    sessionTarget: "isolated",
+    wakeMode: "next-heartbeat",
+    payload: { kind: "agentTurn", message: id },
+    delivery: { mode: "none" },
+    state: { lastRunAtMs, lastRunStatus: "ok", nextRunAtMs: lastRunAtMs + EVERY_MS },
+  };
+}
+
+function createStartupState(params: {
+  storePath: string;
+  skipMissedJobs?: boolean;
+  log?: CronServiceDeps["log"];
+}) {
+  const runIsolatedAgentJob = createDefaultIsolatedRunner();
+  const enqueueSystemEvent = vi.fn();
+  const state = createCronServiceState({
+    cronEnabled: true,
+    storePath: params.storePath,
+    log: params.log ?? {
+      info: () => {},
+      warn: () => {},
+      error: () => {},
+      debug: () => {},
+    },
+    nowMs: () => STARTUP_AT,
+    enqueueSystemEvent,
+    requestHeartbeat: vi.fn(),
+    runIsolatedAgentJob,
+    ...(params.skipMissedJobs === undefined
+      ? {}
+      : { cronConfig: { skipMissedJobs: params.skipMissedJobs } }),
+  });
+  return { state, runIsolatedAgentJob, enqueueSystemEvent };
+}
+
+function requireJob(state: { store?: { jobs?: CronJob[] } | null }, id: string): CronJob {
+  const job = state.store?.jobs?.find((candidate) => candidate.id === id);
+  if (!job) {
+    throw new Error(`expected cron job ${id}`);
+  }
+  return job;
+}
+
+describe("cron startup skipMissedJobs", () => {
+  it("fast-forwards missed recurring jobs instead of replaying them", async () => {
+    const store = fixtures.makeStorePath();
+    await saveCronStore(store.storePath, {
+      version: 1,
+      jobs: [createMissedDailyCronJob("missed-daily"), createMissedEveryJob("missed-every")],
+    });
+    const logInfo = vi.fn();
+    const { state, runIsolatedAgentJob, enqueueSystemEvent } = createStartupState({
+      storePath: store.storePath,
+      skipMissedJobs: true,
+      log: { info: logInfo, warn: () => {}, error: () => {}, debug: () => {} },
+    });
+
+    await runMissedJobs(state, { deferAgentTurnJobs: true });
+
+    expect(runIsolatedAgentJob).not.toHaveBeenCalled();
+    expect(enqueueSystemEvent).not.toHaveBeenCalled();
+    const dailyJob = requireJob(state, "missed-daily");
+    expect(dailyJob.state.nextRunAtMs).toBe(NEXT_SLOT_AT);
+    const everyJob = requireJob(state, "missed-every");
+    const everyNext = everyJob.state.nextRunAtMs ?? 0;
+    expect(everyNext).toBeGreaterThan(STARTUP_AT);
+    expect(everyNext).toBeLessThanOrEqual(STARTUP_AT + EVERY_MS);
+    const skipLog = logInfo.mock.calls.find(
+      (call) => call[1] === "cron: skipping missed jobs after restart",
+    );
+    expect(skipLog?.[0]).toMatchObject({ skipMissedJobs: true, skippedCount: 2 });
+
+    // The first regular tick must not pick the fast-forwarded jobs back up.
+    await onTimer(state);
+    expect(runIsolatedAgentJob).not.toHaveBeenCalled();
+    expect(enqueueSystemEvent).not.toHaveBeenCalled();
+  });
+
+  it("keeps missed one-shot jobs on the default catch-up path", async () => {
+    const store = fixtures.makeStorePath();
+    await saveCronStore(store.storePath, {
+      version: 1,
+      jobs: [
+        createMissedDailyCronJob("missed-daily"),
+        createDueIsolatedJob({
+          id: "missed-one-shot",
+          nowMs: LAST_RUN_AT,
+          nextRunAtMs: MISSED_SLOT_AT,
+        }),
+      ],
+    });
+    const { state, runIsolatedAgentJob } = createStartupState({
+      storePath: store.storePath,
+      skipMissedJobs: true,
+    });
+
+    await runMissedJobs(state);
+
+    expect(runIsolatedAgentJob).toHaveBeenCalledTimes(1);
+    const oneShotJob = requireJob(state, "missed-one-shot");
+    expect(oneShotJob.state.lastStatus).toBe("ok");
+    const dailyJob = requireJob(state, "missed-daily");
+    expect(dailyJob.state.lastStatus).toBeUndefined();
+    expect(dailyJob.state.nextRunAtMs).toBe(NEXT_SLOT_AT);
+  });
+
+  it("catches up missed recurring jobs when skipMissedJobs is not enabled", async () => {
+    const store = fixtures.makeStorePath();
+    await saveCronStore(store.storePath, {
+      version: 1,
+      jobs: [createMissedDailyCronJob("missed-daily")],
+    });
+    const { state, runIsolatedAgentJob } = createStartupState({
+      storePath: store.storePath,
+    });
+
+    await runMissedJobs(state);
+
+    expect(runIsolatedAgentJob).toHaveBeenCalledTimes(1);
+    const dailyJob = requireJob(state, "missed-daily");
+    expect(dailyJob.state.lastStatus).toBe("ok");
+  });
+});
