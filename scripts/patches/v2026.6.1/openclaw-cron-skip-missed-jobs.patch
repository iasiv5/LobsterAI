+/**
+ * Fast-forwards recurring (cron/every) jobs whose slots were missed while the
+ * gateway was offline, advancing nextRunAtMs to the next occurrence from now
+ * (cron.skipMissedJobs). One-shot ("at") jobs are left untouched so they keep
+ * the default startup catch-up semantics. Returns the fast-forwarded job ids
+ * so the caller can exclude them from the catch-up plan; the caller persists.
+ */
+function fastForwardMissedRecurringJobs(
+  state: CronServiceState,
+  opts?: { skipJobIds?: ReadonlySet<string> },
+): ReadonlySet<string> {
+  const now = state.deps.nowMs();
+  const missed = collectRunnableJobs(state, now, {
+    skipJobIds: opts?.skipJobIds,
+    skipAtIfAlreadyRan: true,
+    allowCronMissedRunByLastRun: true,
+  }).filter((job) => job.schedule.kind !== "at");
+  const skippedJobs: Array<{
+    jobId: string;
+    name: string;
+    previousNextRunAtMs: number | undefined;
+    nextRunAtMs: number | undefined;
+  }> = [];
+  for (const job of missed) {
+    const previousNextRunAtMs = job.state.nextRunAtMs;
+    recomputeJobNextRunAtMs({ state, job, nowMs: now });
+    skippedJobs.push({
+      jobId: job.id,
+      name: job.name,
+      previousNextRunAtMs,
+      nextRunAtMs: job.state.nextRunAtMs,
+    });
+  }
+  state.deps.log.info(
+    { skipMissedJobs: true, skippedCount: skippedJobs.length, skippedJobs },
+    "cron: skipping missed jobs after restart",
+  );
+  return new Set(skippedJobs.map((entry) => entry.jobId));
+}
